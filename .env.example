# Database Connections
# --------------------
# PostgreSQL Connection URL (Used by Prisma)
DATABASE_URL='postgresql://postgres:password@localhost:5432/pageview'

# Toggles PostgreSQL storage adapter (enabled by default)
ENABLE_POSTGRES=true


# Google Analytics (Optional)
# ---------------------------
NEXT_PUBLIC_MEASUREMENT_ID='G-MBMTG02C2R'


# ClickHouse Analytics Adapter (Optional)
# ---------------------------------------
# URL Format: http://[user]:[password]@[host]:[port]/[database]?table=[table_name]
# CLICKHOUSE_URL='http://default:password@localhost:8123/default?table=pageviews'


# MotherDuck / DuckDB Adapter (Optional)
# --------------------------------------
# MotherDuck API Token (Enables MotherDuck Cloud adapter)
# MOTHERDUCK_TOKEN='md_token_placeholder'
# MOTHERDUCK_DATABASE='my_db'
# MOTHERDUCK_TABLE='pageviews'

# Toggle to force offline local DuckDB writes (saves data in local pageviews.db file)
# ENABLE_DUCKDB=false


# Custom HTTP Webhook Adapter (Optional)
# --------------------------------------
# URL to POST unified PageViewEvent JSON payloads to
# WEBHOOK_URL='https://api.myproject.com/v1/webhooks/pageviews'

# Secret key used to sign the JSON payload (produces SHA-256 HMAC in X-Webhook-Signature header)
# WEBHOOK_SECRET='my-webhook-signing-secret'
